---
import Layout from "../../../components/Layout.astro";
import Heading from "../../../components/Heading.astro";
import { getPublishedPosts } from "../../../lib/posts";

export async function getStaticPaths() {
  const TAG_PAGE_SIZE = 10;
  const allPosts = await getPublishedPosts();
  const tags = [...new Set(allPosts.flatMap((p) => p.data.tags))];

  const paths: { params: { tag: string; page: string }; props: { tag: string; posts: typeof allPosts; totalPages: number; currentPage: number } }[] = [];

  for (const tag of tags) {
    const tagPosts = allPosts.filter((p) => p.data.tags.includes(tag));
    const totalPages = Math.ceil(tagPosts.length / TAG_PAGE_SIZE);
    for (let page = 2; page <= totalPages; page++) {
      paths.push({
        params: { tag, page: String(page) },
        props: {
          tag,
          posts: tagPosts.slice((page - 1) * TAG_PAGE_SIZE, page * TAG_PAGE_SIZE),
          totalPages,
          currentPage: page,
        },
      });
    }
  }

  return paths;
}

const { tag, posts, totalPages, currentPage } = Astro.props;
---

<Layout title={`標籤「${tag}」— WAHSUNNの自留地`} description={`所有標籤為「${tag}」的文章 — 第 ${currentPage} 頁。`}>
  <section class="tag-detail">
    <!-- Breadcrumb -->
    <a href="/tags" class="breadcrumb">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3 L5 7 L9 11"/></svg>
      所有標籤
    </a>

    <!-- Tag Header -->
    <header class="tag-header">
      <a href={`/tags/${tag}`} class="tag-title-link">
        <h1 class="tag-title">{tag}</h1>
      </a>
      <p class="tag-meta">第 {currentPage} 頁</p>
    </header>

    <ul class="post-list">
      {posts.map((post) => {
        const formattedDate = post.data.date.toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        });
        return (
          <li class="post-item ink-border">
            <a href={`/posts/${post.id}`}>
              <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
              <span class="post-title">{post.data.title}</span>
              <span class="post-description">{post.data.description}</span>
            </a>
          </li>
        );
      })}
    </ul>

    <!-- Pagination -->
    <nav class="pagination" aria-label="Pagination">
      {currentPage > 1 && (
        <a href={currentPage === 2 ? `/tags/${tag}` : `/tags/${tag}/${currentPage - 1}`} class="pagination-link">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2 L4 6 L8 10"/></svg>
          較新文章
        </a>
      )}
      <span class="pagination-info">第 {currentPage} 頁，共 {totalPages} 頁</span>
      {currentPage < totalPages && (
        <a href={`/tags/${tag}/${currentPage + 1}`} class="pagination-link">
          較舊文章
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="M4 2 L8 6 L4 10"/></svg>
        </a>
      )}
    </nav>
  </section>
</Layout>

<style>
  .tag-detail {
    max-width: var(--width-content);
  }

  .breadcrumb {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    text-decoration: none;
    margin-bottom: var(--space-md);
    transition: color 0.2s ease;
  }
  .breadcrumb:hover { color: var(--color-text); }

  .tag-header {
    margin-bottom: var(--space-lg);
    animation: fadeUp 0.5s ease both;
  }

  .tag-title-link {
    text-decoration: none;
    color: var(--color-text);
  }

  .tag-title {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: var(--space-xs);
  }

  .tag-meta {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
  }

  .post-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    animation: fadeUp 0.5s ease 0.1s both;
  }

  .post-item {
    padding: var(--space-lg);
    background: var(--color-surface);
    transition: border-color 0.35s ease, box-shadow 0.35s ease, transform 0.3s ease;
  }
  .post-item:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 1px var(--color-ink-light), 0 4px 20px var(--color-ink-medium);
    transform: translateY(-2px);
  }

  .post-item a {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    text-decoration: none;
    color: var(--color-text);
  }

  .post-item time {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
    transition: color 0.2s ease;
  }
  .post-item a:hover .post-title { color: var(--color-text-secondary); }

  .post-description {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    position: relative;
  }
  .pagination::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, var(--color-border) 0%, transparent 80%);
  }

  .pagination-link {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
  }
  .pagination-link:hover { color: var(--color-text); }

  .pagination-info {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  @media (max-width: 600px) {
    .tag-title { font-size: 1.5rem; }
    .post-item { padding: var(--space-md); }
  }
</style>
