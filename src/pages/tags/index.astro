---
import Layout from "../../components/Layout.astro";
import Heading from "../../components/Heading.astro";
import { getPublishedPosts } from "../../lib/posts";

const posts = await getPublishedPosts();

const tagCounts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  }
}
const sortedTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
const TOTAL_TAGS = sortedTags.length;
const MAX_COUNT = Math.max(1, ...sortedTags.map(([, c]) => c));

const GROUP_DEFS: { name: string; color: string; members: string[] }[] = [
  { name: "心理·認知", color: "#7eb8da", members: ["心理學", "認知", "認知升級", "認知偏誤", "認知科學", "認知重啟", "達克效應", "思維模型", "雙重思維", "大五人格"] },
  { name: "社會·群體", color: "#c08497", members: ["社會觀察", "群體心理", "道德勇氣", "叢林法則", "實力思維", "國際政治", "權力", "體制", "高校", "奧威爾", "1984"] },
  { name: "自我·成長", color: "#7fc6a4", members: ["獨立思考", "自我", "成長", "自我成長", "自我覺察", "自我覺醒", "原生家庭", "個人成長", "內生力量", "強大", "生活的意義", "時間管理", "工作生活平衡", "嚴肅愛好"] },
  { name: "思維·哲學", color: "#b8a07c", members: ["哲學", "系統思維", "批判思考", "人生哲學", "存在主義", "理性", "精神自治", "秩序", "智慧", "三觀"] },
  { name: "資訊·時代", color: "#a08cbb", members: ["演算法", "資訊繭房", "知識泡沫", "思維泡沫", "精神速食", "知識付費", "知識分子"] },
  { name: "角色·面具", color: "#cc9a7a", members: ["面具", "虛偽", "性格", "心理"] },
];

const tagToGroup = new Map<string, number>();
GROUP_DEFS.forEach((g, gi) => { g.members.forEach((t) => tagToGroup.set(t, gi)); });

const groups = GROUP_DEFS.map((g) => ({ name: g.name, color: g.color, tags: [] as { name: string; count: number }[] }));
const orphans: { name: string; count: number }[] = [];

for (const [tag, count] of sortedTags) {
  const gi = tagToGroup.get(tag);
  if (gi !== undefined) groups[gi].tags.push({ name: tag, count });
  else orphans.push({ name: tag, count });
}
if (orphans.length > 0) {
  groups.push({ name: "其他", color: "#9a9a9a", tags: orphans });
}

const NONEMPTY = groups.filter((g) => g.tags.length > 0);
const totalGroups = NONEMPTY.length;
---

<Layout title={`${TOTAL_TAGS} 個主題 — WAHSUNNの自留地`} description={`${TOTAL_TAGS} 個關鍵詞，分布在 ${totalGroups} 個主題領域。`}>
  <section class="tags-page">

    <header class="page-hero">
      <h1 class="page-hero-title">
        <span class="hero-gradient">{TOTAL_TAGS}</span> 個關鍵詞
      </h1>
      <p class="page-hero-meta">{totalGroups} 個主題領域</p>
    </header>

    <div class="tag-landscape">
      {NONEMPTY.map((group) => {
        const groupTotal = group.tags.reduce((s, t) => s + t.count, 0);
        return (
          <div class="tag-group card">
            <div class="group-header">
              <div class="group-title-wrap">
                <span class="group-dot" style={`background:${group.color}`}></span>
                <h2 class="group-name">{group.name}</h2>
              </div>
              <span class="group-total">{groupTotal}</span>
            </div>
            <div class="group-tags">
              {group.tags.map((tag) => {
                const size = 0.85 + (tag.count / MAX_COUNT) * 0.6;
                return (
                  <a href={`/tags/${tag.name}`} class="tag-chip" style={`--chip-color:${group.color};--chip-scale:${size}`}>
                    <span class="chip-name">{tag.name}</span>
                    <span class="chip-count">{tag.count}</span>
                  </a>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>
  </section>
</Layout>

<style>
  .tags-page { padding: 3rem 0 5rem; }

  .page-hero {
    text-align: center;
    padding: 2rem 0 3rem;
  }
  .page-hero-title {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 0.5rem;
  }
  .hero-gradient {
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .page-hero-meta {
    font-size: 1rem;
    color: var(--text-secondary);
    font-style: italic;
  }

  .tag-landscape {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    animation: fadeUp 0.6s ease 0.1s both;
  }

  .tag-group {
    padding: 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.2s;
  }
  .tag-group:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .group-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }
  .group-title-wrap {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }
  .group-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    transition: transform 0.3s;
  }
  .tag-group:hover .group-dot { transform: scale(1.4); }
  .group-name {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
  }
  .group-total {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-tertiary);
    font-variant-numeric: tabular-nums;
  }

  .group-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-chip {
    --chip-scale: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.25rem 0.7rem 0.25rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    text-decoration: none;
    font-family: var(--font-heading);
    font-size: calc(0.8125rem * var(--chip-scale));
    color: var(--text-secondary);
    transition: all 0.25s;
    line-height: 1.4;
  }
  .tag-chip:hover {
    border-color: var(--chip-color, var(--accent));
    background: color-mix(in srgb, var(--chip-color, var(--accent)) 8%, transparent);
    color: var(--text);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--chip-color, var(--accent)) 10%, transparent);
  }
  .chip-count {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    padding: 0.05rem 0.3rem;
    border-radius: 999px;
    background: var(--accent-subtle);
    transition: background 0.25s;
    font-variant-numeric: tabular-nums;
  }
  .tag-chip:hover .chip-count {
    background: color-mix(in srgb, var(--chip-color, var(--accent)) 15%, transparent);
  }

  @media (max-width: 600px) {
    .page-hero-title { font-size: 1.75rem; }
    .tag-group { padding: 1.25rem; }
  }
</style>
