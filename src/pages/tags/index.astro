---
import Layout from "../../components/Layout.astro";
import Heading from "../../components/Heading.astro";
import { getPublishedPosts } from "../../lib/posts";

const posts = await getPublishedPosts();

// Count all tags
const tagCounts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  }
}

const sortedTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));

// ─── Tag group definitions ──────────────────
const GROUP_DEFS: { name: string; en: string; color: string; members: string[] }[] = [
  {
    name: "心理·認知",
    en: "Mind & Cognition",
    color: "#7eb8da",
    members: ["心理學", "認知", "認知升級", "認知偏誤", "認知科學", "認知重啟", "達克效應", "思維模型", "雙重思維", "大五人格"],
  },
  {
    name: "社會·群體",
    en: "Society & The Collective",
    color: "#c08497",
    members: ["社會觀察", "群體心理", "道德勇氣", "叢林法則", "實力思維", "國際政治", "權力", "體制", "高校", "奧威爾", "1984"],
  },
  {
    name: "自我·成長",
    en: "Self & Growth",
    color: "#7fc6a4",
    members: ["獨立思考", "自我", "成長", "自我成長", "自我覺察", "自我覺醒", "原生家庭", "個人成長", "內生力量", "強大", "生活的意義", "時間管理", "工作生活平衡", "嚴肅愛好"],
  },
  {
    name: "思維·哲學",
    en: "Thought & Philosophy",
    color: "#b8a07c",
    members: ["哲學", "系統思維", "批判思考", "人生哲學", "存在主義", "理性", "精神自治", "秩序", "智慧", "三觀"],
  },
  {
    name: "資訊·時代",
    en: "Information Age",
    color: "#a08cbb",
    members: ["演算法", "資訊繭房", "知識泡沫", "思維泡沫", "精神速食", "知識付費", "知識分子"],
  },
  {
    name: "角色·面具",
    en: "Masks & Persona",
    color: "#cc9a7a",
    members: ["面具", "虛偽", "性格", "心理"],
  },
];

// Build groups from actual tag data
const tagToGroup = new Map<string, number>();
GROUP_DEFS.forEach((g, gi) => { g.members.forEach((t) => tagToGroup.set(t, gi)); });

const groups = GROUP_DEFS.map((g) => ({
  name: g.name, en: g.en, color: g.color,
  tags: [] as { name: string; count: number }[],
}));
const orphans: { name: string; count: number }[] = [];

for (const [tag, count] of sortedTags) {
  const gi = tagToGroup.get(tag);
  if (gi !== undefined) groups[gi].tags.push({ name: tag, count });
  else orphans.push({ name: tag, count });
}

if (orphans.length > 0) {
  groups.push({ name: "其他", en: "More", color: "#9a9a9a", tags: orphans });
}

const NONEMPTY = groups.filter((g) => g.tags.length > 0);
const TOTAL_TAGS = sortedTags.length;
const MAX_COUNT = Math.max(1, ...sortedTags.map(([, c]) => c));
---

<Layout title="標籤 — WAHSUNNの自留地" description={`${TOTAL_TAGS} 個關鍵詞，分布在 ${NONEMPTY.length} 個主題領域。`}>
  <section class="tags-page">
    <!-- Hero -->
    <header class="tags-hero">
      <Heading as="h1">
        <span class="hero-heading-main">標籤</span>
      </Heading>
      <p class="hero-subtitle">
        {TOTAL_TAGS} 個關鍵詞 · {NONEMPTY.length} 個領域
      </p>
    </header>

    <!-- Grouped Tag Landscape -->
    <div class="tag-landscape">
      {
        NONEMPTY.map((group) => {
          const groupTotal = group.tags.reduce((s, t) => s + t.count, 0);
          return (
            <div class="tag-group">
              <div class="group-header">
                <div class="group-title-wrap">
                  <span class="group-dot" style={`background:${group.color}`}></span>
                  <h2 class="group-name">{group.name}</h2>
                  <span class="group-en">{group.en}</span>
                </div>
                <span class="group-total">{groupTotal}</span>
              </div>
              <div class="group-tags">
                {group.tags.map((tag) => {
                  const size = 0.8 + (tag.count / MAX_COUNT) * 0.7;
                  return (
                    <a href={`/tags/${tag.name}`} class="tag-chip" style={`--chip-color:${group.color};--chip-scale:${size}`}>
                      <span class="chip-name">{tag.name}</span>
                      <span class="chip-count">{tag.count}</span>
                    </a>
                  );
                })}
              </div>
            </div>
          );
        })
      }
    </div>
  </section>
</Layout>

<style>
  .tags-page {
    max-width: var(--width-content);
  }

  /* ─── Hero ──────────────────────────────── */
  .tags-hero {
    margin-bottom: var(--space-xl);
    animation: fadeUp 0.5s ease both;
  }

  .hero-heading-main {
    display: inline-block;
    position: relative;
  }
  .hero-heading-main::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 15%;
    right: 15%;
    height: 2px;
    background: var(--color-accent);
    opacity: 0.3;
    border-radius: 1px;
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-tertiary);
    margin-top: var(--space-md);
    font-style: italic;
    animation: fadeIn 0.6s ease 0.15s both;
  }

  /* ─── Tag Groups ────────────────────────── */
  .tag-landscape {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    animation: fadeUp 0.5s ease 0.15s both;
  }

  .tag-group {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: var(--space-lg);
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .tag-group:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 1px var(--color-ink-light);
  }

  .group-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-md);
  }

  .group-title-wrap {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .group-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .tag-group:hover .group-dot {
    transform: scale(1.35);
  }

  .group-name {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .group-en {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    color: var(--color-text-tertiary);
    letter-spacing: 0.04em;
  }

  .group-total {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    font-variant-numeric: tabular-nums;
  }

  /* ─── Tag Chips ─────────────────────────── */
  .group-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .tag-chip {
    --chip-scale: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.75rem 0.3rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 100px;
    text-decoration: none;
    font-family: var(--font-heading);
    font-size: calc(0.8125rem * var(--chip-scale));
    color: var(--color-text-secondary);
    transition: border-color 0.25s ease, background 0.25s ease, color 0.25s ease, transform 0.2s ease, box-shadow 0.25s ease;
  }

  .tag-chip:hover {
    border-color: var(--chip-color);
    background: color-mix(in srgb, var(--chip-color) 8%, transparent);
    color: var(--color-text);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--chip-color) 10%, transparent);
  }

  .chip-count {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-tertiary);
    padding: 0.05rem 0.3rem;
    border-radius: 100px;
    background: var(--color-ink-light);
    transition: background 0.25s ease, color 0.25s ease;
    font-variant-numeric: tabular-nums;
    line-height: 1.3;
  }

  .tag-chip:hover .chip-count {
    background: color-mix(in srgb, var(--chip-color) 15%, transparent);
    color: var(--color-text-secondary);
  }

  /* ─── Responsive ────────────────────────── */
  @media (max-width: 600px) {
    .tag-group { padding: var(--space-md); }
    .group-en { display: none; }
    .tag-chip { font-size: calc(0.75rem * var(--chip-scale)); padding: 0.2rem 0.6rem 0.2rem 0.7rem; }
  }
</style>
