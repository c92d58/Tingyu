---
import Layout from "../../components/Layout.astro";
import Heading from "../../components/Heading.astro";
import { getPublishedPosts } from "../../lib/posts";
import type { GetStaticPathsOptions } from "astro";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getPublishedPosts();
  const pages = paginate(posts, { pageSize: 10 });
  return pages.filter((p) => p.params.page !== '1');
}

const { page } = Astro.props;
---

<Layout title={`第 ${page.currentPage} 頁 — WAHSUNNの自留地`}>
  <section class="home">
    <header class="page-header">
      <Heading as="h1">
        文章
        <span class="page-sub">· 第 {page.currentPage} 頁</span>
      </Heading>
      <p class="page-tagline">共 {page.lastPage} 頁 · 持續書寫中</p>
    </header>

    <ul class="post-list">
      {page.data.map((post, index) => {
        const formattedDate = post.data.date.toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        });
        return (
          <li class="post-item ink-border animate-fade-up delay-{Math.min(index + 1, 6)}" data-index={page.start + index + 1}>
            <a href={`/posts/${post.id}`}>
              <span class="post-meta">
                <span class="post-number">#{(page.start + index + 1).toString().padStart(2, '0')}</span>
                <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
              </span>
              <span class="post-title">{post.data.title}</span>
              <span class="post-description">{post.data.description}</span>
            </a>
          </li>
        );
      })}
    </ul>

    <nav class="pagination" aria-label="Pagination">
      {page.url.prev && (
        <a href={page.currentPage === 2 ? "/" : page.url.prev} class="pagination-link">
          <span class="pagination-arrow">←</span>
          較新文章
        </a>
      )}
      <span class="pagination-info">第 {page.currentPage} 頁，共 {page.lastPage} 頁</span>
      {page.url.next && (
        <a href={page.url.next} class="pagination-link">
          較舊文章
          <span class="pagination-arrow">→</span>
        </a>
      )}
    </nav>
  </section>
</Layout>

<style>
  .home {
    max-width: var(--width-content);
  }

  .page-header {
    margin-bottom: var(--space-lg);
  }

  .page-sub {
    font-weight: 400;
    font-size: 0.8em;
    color: var(--color-text-tertiary);
  }

  .page-tagline {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-tertiary);
    margin-top: var(--space-xs);
    font-style: italic;
  }

  /* ─── Post List ──────────────────────────── */
  .post-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  /* ─── Post Item ──────────────────────────── */
  .post-item {
    padding: var(--space-md);
    background: var(--color-surface);
    transition: border-color 0.35s ease, box-shadow 0.35s ease, transform 0.3s ease;
  }

  .post-item:hover {
    border-color: var(--color-accent);
    box-shadow:
      0 0 0 1px var(--color-ink-light),
      0 4px 20px var(--color-ink-medium);
    transform: translateY(-2px);
  }

  .post-item a {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    text-decoration: none;
    color: var(--color-text);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  .post-number {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-accent);
    letter-spacing: 0.02em;
  }

  .post-item time {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  .post-item a:hover .post-title {
    color: var(--color-text-secondary);
  }

  .post-description {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* ─── Pagination ────────────────────────── */
  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    position: relative;
  }

  .pagination::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, var(--color-border) 0%, transparent 80%);
  }

  .pagination-link {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .pagination-link:hover {
    color: var(--color-text);
  }

  .pagination-arrow {
    transition: transform 0.2s ease;
  }

  .pagination-link:hover .pagination-arrow {
    transform: translateX(2px);
  }
  .pagination-link:first-child:hover .pagination-arrow {
    transform: translateX(-2px);
  }

  .pagination-info {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  @media (max-width: 600px) {
    .post-item { padding: var(--space-md); }
  }
</style>
