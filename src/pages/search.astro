---
import Layout from "../components/Layout.astro";
import { getPublishedPosts } from "../lib/posts";

const allPosts = await getPublishedPosts();

const tagCounts = new Map<string, number>();
for (const post of allPosts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  }
}
const topTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 12);
const tagSuggestions = JSON.stringify(topTags);
const totalArticles = allPosts.length;
---

<Layout title="搜尋 — WAHSUNの自留地" description="全文搜尋文章，或隨機發現好內容。">
  <section class="search-page">

    <header class="page-hero">
      <h1 class="page-hero-title">
        <span class="hero-gradient">{totalArticles}</span> 篇文章
      </h1>
      <p class="page-hero-meta">全文搜尋，或隨機發現</p>
    </header>

    <div class="search-input-wrap card">
      <div class="search-icon">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <circle cx="7.5" cy="7.5" r="5.5"/><path d="M11.5 11.5 L16 16"/>
        </svg>
      </div>
      <input type="text" id="search-input" placeholder="輸入關鍵字..." autocomplete="off" autofocus />
      <button id="search-clear" class="search-clear" aria-label="清除">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M3 3 L11 11 M11 3 L3 11"/></svg>
      </button>
    </div>

    <div id="initial-state" class="initial-state">
      <div class="suggest-section card">
        <div class="suggest-header">
          <h2 class="suggest-title">熱門主題</h2>
          <span class="suggest-count">{topTags.length}</span>
        </div>
        <div class="tag-cloud" id="tag-cloud">
          {topTags.map(([tag, count]) => {
            const size = 0.85 + (count / topTags[0][1]) * 0.5;
            return (
              <button class="tag-pill" data-tag={tag} style={`--pill-scale:${size}`} title={`${tag}（${count} 篇）`}>{tag}</button>
            );
          })}
        </div>
      </div>

      <div class="suggest-section card">
        <div class="suggest-header">
          <h2 class="suggest-title">隨機推薦</h2>
          <button id="shuffle-btn" class="shuffle-btn" title="換一批">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 4 L4 4 C5.5 4 6.5 2 8 2 L13 2"/><path d="M1 10 L4 10 C5.5 10 6.5 12 8 12 L13 12"/>
              <path d="M10 6 L13 4 L10 2"/><path d="M10 8 L13 10 L10 12"/>
            </svg>
            換一批
          </button>
        </div>
        <div id="random-posts" class="random-posts"></div>
      </div>
    </div>

    <ul id="search-results" class="search-results"></ul>
    <div id="search-empty" class="search-empty" hidden>
      <p>找不到相關文章</p>
      <p class="empty-hint">試試其他關鍵字，或瀏覽熱門主題</p>
    </div>
  </section>
</Layout>

<div id="tag-data" style="display:none">{tagSuggestions}</div>

<script>
interface SearchEntry { slug: string; title: string; description: string; date: string; tags: string[]; body: string; }

const TAG_SUGGESTIONS: [string, number][] = JSON.parse(document.getElementById("tag-data")?.textContent || "[]");
let index: SearchEntry[] = [];
let loaded = false;

const input = document.getElementById("search-input") as HTMLInputElement;
const clearBtn = document.getElementById("search-clear") as HTMLButtonElement;
const resultsList = document.getElementById("search-results") as HTMLUListElement;
const emptyMsg = document.getElementById("search-empty") as HTMLDivElement;
const initialState = document.getElementById("initial-state") as HTMLDivElement;
const randomPosts = document.getElementById("random-posts") as HTMLDivElement;
const shuffleBtn = document.getElementById("shuffle-btn") as HTMLButtonElement;
const tagCloud = document.getElementById("tag-cloud") as HTMLDivElement;

async function loadIndex(): Promise<void> {
  if (loaded) return;
  try {
    const res = await fetch("/search-index.json");
    if (!res.ok) throw new Error(`Failed: ${res.status}`);
    index = await res.json();
    loaded = true;
    renderRandomPosts();
  } catch (err) {
    console.error(err);
    randomPosts.innerHTML = `<p class="error-hint">暫時無法載入推薦</p>`;
  }
}

function pickRandom(n: number): SearchEntry[] {
  if (index.length === 0) return [];
  const shuffled = [...index];
  for (let i = shuffled.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
  }
  return shuffled.slice(0, n);
}

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}

function escapeHtml(str: string): string {
  const div = document.createElement("div");
  div.textContent = str;
  return div.innerHTML;
}

function renderRandomPosts(): void {
  const picks = pickRandom(3);
  randomPosts.innerHTML = picks.map((p) => `
    <a href="/posts/${encodeURIComponent(p.slug)}" class="random-card">
      <span class="random-meta">${p.tags.slice(0, 2).map((t) => `<span class="random-tag">${escapeHtml(t)}</span>`).join("")} · ${formatDate(p.date)}</span>
      <span class="random-title">${escapeHtml(p.title)}</span>
    </a>
  `).join("");
}

tagCloud.addEventListener("click", (e) => {
  const btn = (e.target as HTMLElement).closest("[data-tag]") as HTMLButtonElement;
  if (!btn) return;
  input.value = btn.dataset.tag ?? "";
  input.dispatchEvent(new Event("input"));
  input.focus();
});

shuffleBtn.addEventListener("click", () => { renderRandomPosts(); });

function search(query: string): SearchEntry[] {
  const terms = query.toLowerCase().split(/\s+/).filter(Boolean);
  if (terms.length === 0) return [];
  return index.filter((entry) => {
    const haystack = `${entry.title} ${entry.description} ${entry.tags.join(" ")} ${entry.body}`.toLowerCase();
    return terms.every((term) => haystack.includes(term));
  });
}

function render(results: SearchEntry[], query: string): void {
  resultsList.innerHTML = "";
  initialState.hidden = results.length > 0 || query.trim() !== "";
  if (query.trim() === "") { emptyMsg.hidden = true; return; }
  if (results.length === 0) { emptyMsg.hidden = false; return; }
  emptyMsg.hidden = true;
  for (const entry of results) {
    const li = document.createElement("li");
    li.className = "search-result-item card";
    li.innerHTML = `
      <a href="/posts/${encodeURIComponent(entry.slug)}" class="result-link">
        <span class="result-meta">${entry.tags.slice(0, 2).map((t) => `<span class="result-tag">${escapeHtml(t)}</span>`).join("")} · ${formatDate(entry.date)}</span>
        <span class="result-title">${escapeHtml(entry.title)}</span>
        <span class="result-desc">${escapeHtml(entry.description)}</span>
      </a>
    `;
    resultsList.appendChild(li);
  }
}

let debounceTimer: ReturnType<typeof setTimeout>;
input.addEventListener("input", () => {
  clearTimeout(debounceTimer);
  clearBtn.classList.toggle("visible", input.value.length > 0);
  debounceTimer = setTimeout(async () => {
    await loadIndex();
    render(search(input.value), input.value);
  }, 200);
});
clearBtn.addEventListener("click", () => {
  input.value = "";
  clearBtn.classList.remove("visible");
  input.dispatchEvent(new Event("input"));
  input.focus();
});
loadIndex();
</script>

<style>
  .search-page { padding: 3rem 0 5rem; }

  .page-hero {
    text-align: center;
    padding: 2rem 0 2.5rem;
  }
  .page-hero-title {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 0.5rem;
  }
  .hero-gradient {
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .page-hero-meta {\n    font-size: 0.875rem;\n    color: var(--text-secondary);\n    font-style: italic;\n  }

  .search-input-wrap {
    position: relative;
    margin-bottom: 2rem;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    animation: fadeUp 0.5s ease 0.1s both;
  }
  .search-icon { color: var(--text-tertiary); display: flex; }
  #search-input {
    flex: 1;
    font-family: var(--font-heading);
    font-size: 1rem;
    border: none;
    background: transparent;
    color: var(--text);
    outline: none;
  }
  #search-input::placeholder { color: var(--text-tertiary); }
  .search-clear {
    background: none;
    border: none;
    color: var(--text-tertiary);
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 50%;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
  }
  .search-clear.visible { opacity: 1; pointer-events: auto; }
  .search-clear:hover { color: var(--text); }

  .initial-state { animation: fadeUp 0.5s ease 0.15s both; }

  .suggest-section {
    padding: 1.5rem;
    margin-bottom: 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: border-color 0.3s, box-shadow 0.3s;
  }
  .suggest-section:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
  }

  .suggest-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .suggest-title {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
  }
  .suggest-count {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }
  .shuffle-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-secondary);
    background: none;
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.25rem 0.75rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .shuffle-btn:hover {
    color: var(--text);
    border-color: var(--accent);
    background: var(--accent-subtle);
  }

  .tag-cloud { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tag-pill {
    --pill-scale: 1;
    font-family: var(--font-heading);
    font-size: calc(0.8125rem * var(--pill-scale));
    color: var(--text-secondary);
    background: var(--accent-subtle);
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0.3rem 0.85rem;
    cursor: pointer;
    transition: all 0.25s;
    line-height: 1.3;
  }
  .tag-pill:hover {
    border-color: var(--accent);
    color: var(--text);
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }

  .random-posts { display: flex; flex-direction: column; gap: 0.75rem; }
  .random-card {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--text);
    transition: background 0.2s;
  }
  .random-card:hover { background: var(--surface-hover); }
  .random-meta {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }
  .random-tag {
    display: inline-block;
    padding: 0.1rem 0.5rem;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--accent);
    background: var(--accent-subtle);
    border-radius: 999px;
  }
  .random-title {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.35;
  }
  .random-card:hover .random-title {
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .search-results { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .search-result-item {
    padding: 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: all 0.2s;
  }
  .search-result-item:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .result-link { display: flex; flex-direction: column; gap: 0.375rem; text-decoration: none; color: var(--text); }
  .result-meta {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }
  .result-tag {
    display: inline-block;
    padding: 0.1rem 0.5rem;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--accent);
    background: var(--accent-subtle);
    border-radius: 999px;
  }
  .result-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.35;
  }
  .search-result-item:hover .result-title {
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .result-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .search-empty {
    text-align: center;
    padding: 3rem 0;
    color: var(--text-tertiary);
    font-style: italic;
  }
  .empty-hint { font-size: 0.875rem; margin-top: 0.5rem; }

  @media (max-width: 600px) {
    .page-hero-title { font-size: 1.5rem; }
    .suggest-section { padding: 1.25rem; }
  }
</style>
