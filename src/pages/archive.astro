---
import Layout from "../components/Layout.astro";
import { getPublishedPosts } from "../lib/posts";

const allPosts = await getPublishedPosts();

// Group posts by year
const yearGroups = new Map<number, typeof allPosts>();
for (const post of allPosts) {
  const year = post.data.date.getFullYear();
  if (!yearGroups.has(year)) yearGroups.set(year, []);
  yearGroups.get(year)!.push(post);
}
const sortedYears = [...yearGroups.keys()].sort((a, b) => b - a);
const totalArticles = allPosts.length;
---

<Layout title="歸檔 — WAHSUNの自留地" description={`共 ${totalArticles} 篇文章，按時間排列。`}>
  <section class="archive-page">

    <header class="page-hero">
      <h1 class="page-hero-title animate-fade-up delay-1">
        <span class="hero-gradient">歸檔</span>
      </h1>
      <p class="page-hero-meta animate-fade-up delay-2">
        共 <strong>{totalArticles}</strong> 篇文章
      </p>
    </header>

    <div class="timeline">
      {sortedYears.map((year) => (
        <div class="timeline-year animate-fade-up">
          <div class="year-label-wrap">
            <div class="year-dot"></div>
            <span class="section-label">{year}</span>
          </div>

          {yearGroups.get(year)!.map((post) => {
            const formattedDate = post.data.date.toLocaleDateString("en-US", {
              month: "short",
              day: "numeric",
            });
            return (
              <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-body">
                  <time class="timeline-date" datetime={post.data.date.toISOString()}>{formattedDate}</time>
                  <a href={`/posts/${post.id}`} class="timeline-title">{post.data.title}</a>
                </div>
              </div>
            );
          })}
        </div>
      ))}
    </div>

    {totalArticles === 0 && (
      <p class="archive-empty">暫無文章</p>
    )}
  </section>
</Layout>

<style>
  .archive-page { padding: 1rem 0 4rem; }

  /* ─── Hero ──────────────────────────────── */
  .page-hero {
    text-align: center;
    padding: 2rem 0 2.5rem;
  }
  .page-hero-title {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 0.5rem;
  }
  .hero-gradient {
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    background-size: 200% auto;
    animation: shimmer 4s ease infinite;
  }
  .page-hero-meta {
    font-size: 0.875rem;
    color: var(--text-secondary);
    font-style: italic;
  }
  .page-hero-meta strong {
    font-style: normal;
    font-weight: 600;
  }

  /* ─── Timeline ──────────────────────────── */
  .timeline {
    position: relative;
    padding-left: 1.75rem;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, var(--accent), var(--border), transparent);
    border-radius: 1px;
  }

  /* ─── Year Label ────────────────────────── */
  .timeline-year {
    position: relative;
    margin-bottom: 2rem;
  }
  .year-label-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding-top: 0.25rem;
  }
  .year-label-wrap .section-label {
    margin-bottom: 0;
  }
  .year-dot {
    position: absolute;
    left: -1.75rem;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--gradient);
    border: 2px solid var(--bg);
    z-index: 2;
    flex-shrink: 0;
  }

  /* ─── Timeline Item ─────────────────────── */
  .timeline-item {
    position: relative;
    padding: 0.375rem 0 0.375rem 0.75rem;
    margin-bottom: 0.25rem;
    border-radius: var(--radius-sm);
    transition: background 0.2s;
  }
  .timeline-item:hover {
    background: var(--surface-hover);
  }
  .timeline-item:last-child {
    margin-bottom: 0;
  }

  .timeline-dot {
    position: absolute;
    left: -1.75rem;
    top: 0.6rem;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--border);
    border: 2px solid var(--bg);
    z-index: 1;
    transition: background 0.25s, transform 0.25s, box-shadow 0.25s;
  }
  .timeline-item:hover .timeline-dot {
    background: var(--accent);
    transform: scale(1.35);
    box-shadow: 0 0 0 3px var(--accent-subtle);
  }

  .timeline-body {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .timeline-date {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-tertiary);
    white-space: nowrap;
    flex-shrink: 0;
    min-width: 3.2rem;
  }

  .timeline-title {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.45;
    text-decoration: none;
    transition: color 0.2s;
  }
  .timeline-title:hover {
    color: var(--accent);
  }

  /* ─── Empty state ───────────────────────── */
  .archive-empty {
    text-align: center;
    padding: 4rem 0;
    color: var(--text-tertiary);
    font-style: italic;
  }

  /* ─── Responsive ────────────────────────── */
  @media (max-width: 600px) {
    .page-hero-title { font-size: 1.5rem; }
    .page-hero { padding: 1.5rem 0; }
    .timeline { padding-left: 1.5rem; }
    .year-dot, .timeline-dot { left: -1.5rem; }
    .timeline-body { flex-direction: column; gap: 0.15rem; }
    .timeline-item { padding: 0.5rem 0 0.5rem 0.5rem; }
    .timeline-year { margin-bottom: 1.5rem; }
  }
</style>
